# Application
NODE_ENV=development
PORT=3000

# PostgreSQL (used by Docker Compose and to build DATABASE_URL)
PG_USER=postgres
PG_PASSWORD=change-me-in-production
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=alert_workflow_db

# Database connection (local dev: localhost; Docker Compose overrides with postgres host)
DATABASE_URL=postgresql://postgres:password@localhost:5432/alert_workflow_db

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Logging
LOG_LEVEL=debug

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES=1d


# HTTP rate limiting (requests per IP)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# WebSocket connection rate limiting (connections per IP)
WS_RATE_LIMIT_TTL=60000
WS_RATE_LIMIT_MAX=10


# OpenAI (AI alert suggestions). Prefer OPENAI_API_KEY; API_KEY is accepted as fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_MODEL_FALLBACKS=gpt-4o,gpt-4o-mini,gpt-4-turbo
API_KEY=

